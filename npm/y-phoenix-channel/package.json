{
  "name": "y-phoenix-channel",
  "version": "0.3.0",
  "description": "Phoenix Channel provider for Yjs collaborative editing.",
  "main": "dist/y-phoenix-channel.mjs",
  "types": "dist/y-phoenix-channel.d.mts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "yjs",
    "phoenix",
    "collaborative",
    "websocket"
  ],
  "author": "satore <satoreyo@hotmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/satoren/y-phoenix-channel"
  },
  "bugs": {
    "url": "https://github.com/satoren/y-phoenix-channel/issues"
  },
  "homepage": "https://github.com/satoren/y-phoenix-channel#readme",
  "exports": {
    ".": {
      "types": "./dist/y-phoenix-channel.d.ts",
      "import": "./dist/y-phoenix-channel.mjs",
      "require": "./dist/y-phoenix-channel.cjs"
    }
  },
  "dependencies": {
    "y-protocols": "1.0.7",
    "lib0": "0.2.117"
  },
  "peerDependencies": {
    "phoenix": "^1",
    "yjs": "^13"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/phoenix": "1.6.7",
    "tsdown": "0.22.8",
    "happy-dom": "20.9.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "yjs": "13.6.31",
    "msw-phoenix.channel-binding": "0.3.1"
  }
}
